# ─── Database ────────────────────────────────
DATABASE_URL=postgres://postgres:your_password_here@localhost:5437/irm-insta-ai

# ─── Server ──────────────────────────────────
PORT=3032
NODE_ENV=development

# ─── Rate Limit ───────────────────────────────
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW=60000

# ─── Meta / Facebook App ─────────────────────
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_GRAPH_API_VERSION=v25.0

# ─── Facebook Page ────────────────────────────
FACEBOOK_PAGE_ID=

# ─── Instagram ────────────────────────────────
INSTAGRAM_BUSINESS_ID=

# ─── Webhook ──────────────────────────────────
WEBHOOK_VERIFY_TOKEN=
WEBHOOK_AUTO_REPLY_TEXT=Thanks for your message! We will reply soon.

# ─── Token Encryption ─────────────────────────
# 64-char hex string (32 bytes) for AES-256-GCM
TOKEN_ENCRYPTION_KEY=

# ─── RAG / LLM ────────────────────────────────
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─── External API (Prices, Doctors) ───────────
EXTERNAL_API_BASE_URL=https://rk.etl.uzun.kz/api/v1
OPENROUTER_API_KEY=
LLM_MODEL=openai/gpt-4o-mini
EMBED_MODEL=google/gemini-embedding-2
RAG_TOP_K=5
